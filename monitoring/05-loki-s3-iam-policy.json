{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LokiS3ObjectAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::qa-demo-s3-777/*"
    },
    {
      "Sid": "LokiS3BucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::qa-demo-s3-777"
    }
  ]
}
